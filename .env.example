# Gemini AI API Key (Get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI API Key (Get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Server Port
PORT=3001

# PostgreSQL connection (target DB is auto-created on startup)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/webtest

# ============================================================
# MICROSERVICES (optional — the monolith ignores all of these)
# ============================================================
# Session signing secret. MUST be set to a strong random value in
# any real deployment (shared by monolith + microservices).
SESSION_SECRET=change_me_to_a_long_random_string

# Enable real AI calls in the AI service. Leave unset/false to avoid
# triggering paid Gemini/Groq usage during local runs & smoke tests.
MS_AI_ENABLED=false

# Service ports (defaults shown; monolith stays on 3001)
MS_GATEWAY_PORT=4000
MS_REALTIME_PORT=4001
MS_AI_PORT=4002
MS_ORCHESTRATOR_HEALTH_PORT=4003
MS_WORKER_HEALTH_PORT=4004

# Internal URL the worker uses to reach the AI service
MS_AI_URL=http://127.0.0.1:4002

# Concurrency + safety caps
MS_SCAN_CONCURRENCY=3
MS_DISCOVERY_CONCURRENCY=2
MS_PAGE_CONCURRENCY=3
MS_MAX_PAGES=40

# CORS origin for the gateway (default "*"; set to your frontend origin in prod)
MS_CORS_ORIGIN=*
